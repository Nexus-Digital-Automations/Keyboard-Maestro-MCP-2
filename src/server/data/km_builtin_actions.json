      "category": "control",
      "title": "Pause",
      "description": "Pause macro execution for N seconds.",
      "keywords": ["pause", "wait", "sleep", "delay", "timer"],
      "task_hints": ["wait between steps", "delay before next action", "rate-limit a loop"],
      "parameters": [
        {"label": "seconds", "type": "Number", "required": false, "description": "Duration to pause."}
      ],
      "builder_supported": true,
      "result_targets": []
    },
    {
